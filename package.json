{
  "name": "flyde-minecraft-bedrock",
  "version": "1.0.0-beta.1",
  "private": true,
  "description": "Flyde nodes for Minecraft Bedrock / Education Edition via WebSocket (Free version)",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.js",
    "build:full": "node scripts/build.js --full",
    "generate-maps": "cd scripts && npx ts-node --project tsconfig.json generate-maps.ts",
    "lang:ja": "node scripts/set-lang.js ja_JP",
    "lang:en": "node scripts/set-lang.js en_US",
    "publish:all": "node scripts/publish-all.js",
    "lint:dead-code": "knip"
  },
  "peerDependencies": {
    "@flyde/core": "*",
    "@minecraft/vanilla-data": "*",
    "socket-be": "*"
  },
  "devDependencies": {
    "@flyde/core": "*",
    "@minecraft/vanilla-data": "*",
    "@types/node": "^20.0.0",
    "archiver": "^8.0.0",
    "esbuild": "^0.25.0",
    "knip": "^6.17.1",
    "socket-be": "*",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "flyde",
    "minecraft",
    "minecraft-education",
    "minecraft-bedrock",
    "flow-based-programming",
    "dataflow-programming",
    "visual-programming",
    "education"
  ],
  "homepage": "https://example.com",
  "license": "SEE LICENSE IN LICENSE.md",
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
