{
  "name": "flyde-minecraft-bedrock-ws",
  "version": "1.0.0",
  "description": "Flyde nodes for Minecraft Bedrock / Education Edition via WebSocket",
  "main": "./_nodes/index.flyde.ts",
  "exports": {
    ".": "./_nodes/index.flyde.ts"
  },
  "flyde": {
    "exposes": [
      "_nodes/index.flyde.ts"
    ]
  },
  "files": [
    "_nodes/"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate-maps": "cd scripts && npx ts-node --project tsconfig.json generate-maps.ts",
    "lang:ja": "node scripts/set-lang.js ja",
    "lang:en": "node scripts/set-lang.js en"
  },
  "peerDependencies": {
    "@flyde/core": "*",
    "@minecraft/vanilla-data": "*",
    "socket-be": "*"
  },
  "devDependencies": {
    "@flyde/core": "*",
    "@minecraft/vanilla-data": "*",
    "socket-be": "*",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "flyde",
    "minecraft",
    "minecraft-education",
    "minecraft-bedrock",
    "websocket",
    "visual-programming",
    "block-programming",
    "education",
    "socket-be"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yutari-club/mc-flow-template"
  }
}
