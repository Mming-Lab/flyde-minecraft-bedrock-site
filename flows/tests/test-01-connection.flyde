imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 400
        y: 30
      id: note-001
      inputConfig: {}
      nodeId: Note
      config:
        content: |-
          # TC-001: MinecraftConnect 目視確認
          **操作手順:**
          1. フローを実行する
          2. コンソールに `WebSocket server started on port 8080` が表示されること
          3. Minecraft で `/connect localhost:8080` を入力
          4. Minecraft チャットに `Connected to server` が表示されること
          5. MinecraftConnect ノードが緑（実行済み）になること
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 50
        y: 300
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: disconnect
      inputConfig: {}
      nodeId: MinecraftDisconnect
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 650
        y: 230
      id: note-002
      inputConfig: {}
      nodeId: Note
      config:
        content: |-
          # TC-002: MinecraftDisconnect 目視確認
          **操作手順:**
          1. TC-001 完了後（接続中の状態）で実施
          2. Minecraft でチャットを 1 回送信する
          3. **目視確認:** Minecraft チャットに `Disconnected from server` が表示されること
          4. MinecraftDisconnect ノードが緑になること
          5. 以降は Minecraft から再接続が必要
      type: code
      source:
        type: package
        data: "@flyde/nodes"
  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: disconnect
        pinId: トリガー
  id: TestConnection
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: |
    接続テスト（TC-001, TC-002）目視確認のみ
    TC-001: MinecraftConnect → WSサーバー起動・Minecraft接続を目視確認
    TC-002: チャット送信 → MinecraftDisconnect → 切断を目視確認
