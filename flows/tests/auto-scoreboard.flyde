  connections:
    # フロー入力 → test-12a 最初のノード
    - from:
        insId: "__this"
        pinId: トリガー
      to:
        insId: add-obj
        pinId: トリガー
    # test-12a 内部チェーン
    - from:
        insId: add-obj
        pinId: 目標
      to:
        insId: score-set
        pinId: トリガー
    - from:
        insId: score-set
        pinId: 新スコア
      to:
        insId: assert-sb02
        pinId: 実際値
    - from:
        insId: assert-sb02
        pinId: 完了
      to:
        insId: get-score
        pinId: トリガー
    - from:
        insId: get-score
        pinId: スコア
      to:
        insId: assert-sb03
        pinId: 実際値
    - from:
        insId: assert-sb03
        pinId: 完了
      to:
        insId: score-add
        pinId: トリガー
    - from:
        insId: score-add
        pinId: 新スコア
      to:
        insId: assert-sb04
        pinId: 実際値
    - from:
        insId: assert-sb04
        pinId: 完了
      to:
        insId: remove-obj
        pinId: トリガー
    - from:
        insId: remove-obj
        pinId: 結果
      to:
        insId: assert-sb05
        pinId: 実際値
    # test-12a 最後の assert → test-12b 最初のノード
    - from:
        insId: assert-sb05
        pinId: 完了
      to:
        insId: add-obj-2
        pinId: トリガー
    # test-12b 内部チェーン
    - from:
        insId: add-obj-2
        pinId: 目標
      to:
        insId: get-from-obj-151
        pinId: 目標
    - from:
        insId: get-from-obj-151
        pinId: 目標ID
      to:
        insId: assert-151
        pinId: 実際値
    - from:
        insId: assert-151
        pinId: 完了
      to:
        insId: get-obj
        pinId: トリガー
    - from:
        insId: get-obj
        pinId: 目標
      to:
        insId: get-from-obj-153
        pinId: 目標
    - from:
        insId: get-from-obj-153
        pinId: 目標ID
      to:
        insId: assert-153
        pinId: 実際値
    - from:
        insId: assert-153
        pinId: 完了
      to:
        insId: get-objectives
        pinId: トリガー
    - from:
        insId: get-objectives
        pinId: 目標一覧
      to:
        insId: score-set-2
        pinId: トリガー
    - from:
        insId: score-set-2
        pinId: 新スコア
      to:
        insId: get-scores
        pinId: トリガー
    - from:
        insId: get-scores
        pinId: スコア一覧
      to:
        insId: remove-obj-2
        pinId: トリガー
    # test-12b 最後のノード → フロー出力
    - from:
        insId: remove-obj-2
        pinId: 結果
      to:
        insId: "__this"
        pinId: 完了
  id: AutoScoreboard
  inputs:
    トリガー: "required"
  outputs:
    完了: {}
  inputsPosition:
    トリガー:
      x: -100
      y: 200
  outputsPosition:
    完了:
      x: 950
      y: 3000
  completionOutputs:
    - 完了
  description: |
    自動スコアボードテスト（TC-151〜157）
    TC-151〜153: スコアボード作成・スコア設定・取得
    TC-154〜157: スコアボードクエリ
