        座標B: {type: json, value: {x: 10, y: 0, z: 0}}
        補間値: {type: number, value: 0.5}
      pos: {x: 100, y: 1700}
    - id: assert-125
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 5, y: 0, z: 0}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-125}
      pos: {x: 400, y: 1700}

    # --- TC-126: Vector3Normalize {3,0,0} = {1,0,0} ---
    - id: vec3norm
