      pos: {x: 750, y: 1700}
    - id: assert-126
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 1, y: 0, z: 0}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-126}
      pos: {x: 1050, y: 1700}

    # --- TC-127a: Vector3Dot orthogonal {1,0,0}・{0,1,0} = 0 ---
    - id: vec3dot-ortho
      type: code
      nodeId: Vector3Dot
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        座標A: {type: json, value: {x: 1, y: 0, z: 0}}
        座標B: {type: json, value: {x: 0, y: 1, z: 0}}
      pos: {x: 1400, y: 1700}
    - id: assert-127a
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 0}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-127a}
      pos: {x: 1700, y: 1700}

    # --- TC-127b: Vector3Dot parallel {1,0,0}・{1,0,0} = 1 ---
    - id: vec3dot-para
      type: code
      nodeId: Vector3Dot
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        座標A: {type: json, value: {x: 1, y: 0, z: 0}}
        座標B: {type: json, value: {x: 1, y: 0, z: 0}}
      pos: {x: 100, y: 1950}
    - id: assert-127b
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 1}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-127b}
      pos: {x: 400, y: 1950}

  connections:
    # TC-111
    - {from: {insId: vec3op-add,     pinId: 座標}, to: {insId: assert-111,  pinId: 実際値}}
    # TC-112
    - {from: {insId: vec3op-sub,     pinId: 座標}, to: {insId: assert-112,  pinId: 実際値}}
    # TC-113
    - {from: {insId: vec3op-scale,   pinId: 座標}, to: {insId: assert-113,  pinId: 実際値}}
    # TC-114
    - {from: {insId: vec3op-assemble, pinId: 座標}, to: {insId: assert-114, pinId: 実際値}}
    # TC-115
    - {from: {insId: vec3op-floor,   pinId: 座標}, to: {insId: assert-115,  pinId: 実際値}}
    # TC-116
    - {from: {insId: vec3op-filly,   pinId: 座標}, to: {insId: assert-116,  pinId: 実際値}}
    # TC-117
    - {from: {insId: vec3dist,       pinId: 距離}, to: {insId: assert-117,  pinId: 実際値}}
    # TC-118
    - {from: {insId: vec3tostr,      pinId: 文字列}, to: {insId: assert-118, pinId: 実際値}}
    # TC-119
    - {from: {insId: vec3split, pinId: x}, to: {insId: assert-119x, pinId: 実際値}}
    - {from: {insId: vec3split, pinId: y}, to: {insId: assert-119y, pinId: 実際値}}
    - {from: {insId: vec3split, pinId: z}, to: {insId: assert-119z, pinId: 実際値}}
    # TC-120
    - {from: {insId: clamp-hi, pinId: 結果}, to: {insId: assert-120a, pinId: 実際値}}
    - {from: {insId: clamp-lo, pinId: 結果}, to: {insId: assert-120b, pinId: 実際値}}
    - {from: {insId: clamp-in, pinId: 結果}, to: {insId: assert-120c, pinId: 実際値}}
    # TC-121
    - {from: {insId: aabb-create,    pinId: エリア}, to: {insId: assert-121,  pinId: 実際値}}
    # TC-122
    - {from: {insId: aabb-in-yes,    pinId: 結果}, to: {insId: assert-122a, pinId: 実際値}}
    - {from: {insId: aabb-in-no,     pinId: 結果}, to: {insId: assert-122b, pinId: 実際値}}
    # TC-123
    - {from: {insId: aabb-translate, pinId: エリア}, to: {insId: assert-123,  pinId: 実際値}}
    # TC-124
    - {from: {insId: aabb-int-yes,   pinId: 結果}, to: {insId: assert-124a, pinId: 実際値}}
    - {from: {insId: aabb-int-no,    pinId: 結果}, to: {insId: assert-124b, pinId: 実際値}}
    # TC-125
    - {from: {insId: vec3lerp,       pinId: 結果}, to: {insId: assert-125,  pinId: 実際値}}
    # TC-126
    - {from: {insId: vec3norm,       pinId: 結果}, to: {insId: assert-126,  pinId: 実際値}}
    # TC-127
    - {from: {insId: vec3dot-ortho,  pinId: 値}, to: {insId: assert-127a, pinId: 実際値}}
    - {from: {insId: vec3dot-para,   pinId: 値}, to: {insId: assert-127b, pinId: 実際値}}
