    - id: assert-123
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値:
          type: json
          value:
            min: {x: 5, y: 0, z: 0}
            max: {x: 10, y: 5, z: 5}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-123}
      pos: {x: 400, y: 1450}

    # --- TC-124a: AABBIntersects overlap: 0-5 ∩ 3-8 → true ---
    - id: aabb-int-yes
      type: code
      nodeId: AABBIntersects
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        エリアA:
          type: json
          value:
            min: {x: 0, y: 0, z: 0}
            max: {x: 5, y: 5, z: 5}
        エリアB:
          type: json
          value:
            min: {x: 3, y: 3, z: 3}
            max: {x: 8, y: 8, z: 8}
      pos: {x: 750, y: 1450}
    - id: assert-124a
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: boolean, value: true}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-124a}
      pos: {x: 1050, y: 1450}

    # --- TC-124b: AABBIntersects no-overlap: 0-3 ∩ 5-8 → false ---
    - id: aabb-int-no
      type: code
      nodeId: AABBIntersects
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        エリアA:
          type: json
          value:
            min: {x: 0, y: 0, z: 0}
            max: {x: 3, y: 3, z: 3}
        エリアB:
          type: json
          value:
            min: {x: 5, y: 5, z: 5}
            max: {x: 8, y: 8, z: 8}
      pos: {x: 1400, y: 1450}
    - id: assert-124b
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: boolean, value: false}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-124b}
      pos: {x: 1700, y: 1450}

    # --- TC-125: Vector3Lerp {0,0,0}→{10,0,0} t=0.5 = {5,0,0} ---
    - id: vec3lerp
      type: code
      nodeId: Vector3Lerp
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
