imports: {}
node:
  instances:
    # --- TC-111: Vector3Op add {1,2,3}+{4,5,6} = {5,7,9} ---
    - id: vec3op-add
      type: code
      nodeId: Vector3Op
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        演算: {type: select, value: add}
        座標A: {type: json, value: {x: 1, y: 2, z: 3}}
        座標B: {type: json, value: {x: 4, y: 5, z: 6}}
      pos: {x: 100, y: 100}
    - id: assert-111
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 5, y: 7, z: 9}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-111}
      pos: {x: 400, y: 100}

    # --- TC-112: Vector3Op subtract {5,7,9}-{1,2,3} = {4,5,6} ---
    - id: vec3op-sub
      type: code
      nodeId: Vector3Op
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        演算: {type: select, value: subtract}
        座標A: {type: json, value: {x: 5, y: 7, z: 9}}
        座標B: {type: json, value: {x: 1, y: 2, z: 3}}
      pos: {x: 750, y: 100}
    - id: assert-112
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 4, y: 5, z: 6}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-112}
      pos: {x: 1050, y: 100}

    # --- TC-113: Vector3Op scale {2,4,6}*3 = {6,12,18} ---
    - id: vec3op-scale
      type: code
      nodeId: Vector3Op
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        演算: {type: select, value: scale}
        座標: {type: json, value: {x: 2, y: 4, z: 6}}
        倍率: {type: number, value: 3}
      pos: {x: 1400, y: 100}
    - id: assert-113
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 6, y: 12, z: 18}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-113}
      pos: {x: 1700, y: 100}

    # --- TC-114: Vector3Op assemble x=10,y=20,z=30 ---
    - id: vec3op-assemble
      type: code
      nodeId: Vector3Op
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        演算: {type: select, value: assemble}
        x: {type: number, value: 10}
        y: {type: number, value: 20}
        z: {type: number, value: 30}
      pos: {x: 100, y: 350}
    - id: assert-114
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 10, y: 20, z: 30}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-114}
      pos: {x: 400, y: 350}

    # --- TC-115: Vector3Op floor {1.7,2.3,3.9} = {1,2,3} ---
    - id: vec3op-floor
      type: code
      nodeId: Vector3Op
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        演算: {type: select, value: floor}
        座標: {type: json, value: {x: 1.7, y: 2.3, z: 3.9}}
      pos: {x: 750, y: 350}
    - id: assert-115
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 1, y: 2, z: 3}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-115}
      pos: {x: 1050, y: 350}

    # --- TC-116: Vector3Op fill_y xz={5,10},Y=64 = {5,64,10} ---
    - id: vec3op-filly
      type: code
      nodeId: Vector3Op
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        演算: {type: select, value: fill_y}
        座標XZ: {type: json, value: {x: 5, z: 10}}
        Y: {type: number, value: 64}
      pos: {x: 1400, y: 350}
    - id: assert-116
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: json, value: {x: 5, y: 64, z: 10}}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-116}
      pos: {x: 1700, y: 350}

    # --- TC-117: Vector3Distance (0,0,0)→(3,4,0) = 5 ---
    - id: vec3dist
      type: code
      nodeId: Vector3Distance
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        座標A: {type: json, value: {x: 0, y: 0, z: 0}}
        座標B: {type: json, value: {x: 3, y: 4, z: 0}}
      pos: {x: 100, y: 600}
    - id: assert-117
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 5}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-117}
      pos: {x: 400, y: 600}

    # --- TC-118: Vector3ToString {1,64,-3} = "1 64 -3" ---
    - id: vec3tostr
      type: code
      nodeId: Vector3ToString
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        座標: {type: json, value: {x: 1, y: 64, z: -3}}
      pos: {x: 750, y: 600}
    - id: assert-118
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: string, value: "1 64 -3"}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-118}
      pos: {x: 1050, y: 600}

    # --- TC-119: Vector3Split {10,20,30} → x=10, y=20, z=30 ---
    - id: vec3split
      type: code
      nodeId: Vector3Split
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        座標: {type: json, value: {x: 10, y: 20, z: 30}}
      pos: {x: 1400, y: 620}
    - id: assert-119x
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 10}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-119-x}
      pos: {x: 1700, y: 550}
    - id: assert-119y
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 20}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-119-y}
      pos: {x: 1700, y: 650}
    - id: assert-119z
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 30}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-119-z}
      pos: {x: 1700, y: 750}

    # --- TC-120a: ClampNumber upper 150 clamp(0,100) = 100 ---
    - id: clamp-hi
      type: code
      nodeId: ClampNumber
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        値: {type: number, value: 150}
        最小: {type: number, value: 0}
        最大: {type: number, value: 100}
      pos: {x: 100, y: 950}
    - id: assert-120a
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 100}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-120a}
      pos: {x: 400, y: 950}

    # --- TC-120b: ClampNumber lower -10 clamp(0,100) = 0 ---
    - id: clamp-lo
      type: code
      nodeId: ClampNumber
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        値: {type: number, value: -10}
        最小: {type: number, value: 0}
        最大: {type: number, value: 100}
      pos: {x: 750, y: 950}
    - id: assert-120b
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 0}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-120b}
      pos: {x: 1050, y: 950}

    # --- TC-120c: ClampNumber in-range 50 clamp(0,100) = 50 ---
    - id: clamp-in
      type: code
      nodeId: ClampNumber
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        値: {type: number, value: 50}
        最小: {type: number, value: 0}
        最大: {type: number, value: 100}
      pos: {x: 1400, y: 950}
    - id: assert-120c
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: number, value: 50}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-120c}
      pos: {x: 1700, y: 950}

    # --- TC-121: AABBCreate {0,0,0},{5,5,5} → {min:{0,0,0},max:{5,5,5}} ---
    - id: aabb-create
      type: code
      nodeId: AABBCreate
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        角座標A: {type: json, value: {x: 0, y: 0, z: 0}}
        角座標B: {type: json, value: {x: 5, y: 5, z: 5}}
      pos: {x: 100, y: 1200}
    - id: assert-121
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値:
          type: json
          value:
            min: {x: 0, y: 0, z: 0}
            max: {x: 5, y: 5, z: 5}
        比較: {type: select, value: deep}
        ID: {type: string, value: TC-121}
      pos: {x: 400, y: 1200}

    # --- TC-122a: AABBIsInside inside: pos={2,2,2} → true ---
    - id: aabb-in-yes
      type: code
      nodeId: AABBIsInside
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        エリア:
          type: json
          value:
            min: {x: 0, y: 0, z: 0}
            max: {x: 5, y: 5, z: 5}
        座標: {type: json, value: {x: 2, y: 2, z: 2}}
      pos: {x: 750, y: 1200}
    - id: assert-122a
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: boolean, value: true}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-122a}
      pos: {x: 1050, y: 1200}

    # --- TC-122b: AABBIsInside outside: pos={10,10,10} → false ---
    - id: aabb-in-no
      type: code
      nodeId: AABBIsInside
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        エリア:
          type: json
          value:
            min: {x: 0, y: 0, z: 0}
            max: {x: 5, y: 5, z: 5}
        座標: {type: json, value: {x: 10, y: 10, z: 10}}
      pos: {x: 1400, y: 1200}
    - id: assert-122b
      type: code
      nodeId: Assert
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        期待値: {type: boolean, value: false}
        比較: {type: select, value: eq}
        ID: {type: string, value: TC-122b}
      pos: {x: 1700, y: 1200}

    # --- TC-123: AABBTranslate area+{5,0,0} → {min:{5,0,0},max:{10,5,5}} ---
    - id: aabb-translate
      type: code
      nodeId: AABBTranslate
      source: {type: file, data: "../../_nodes/index.flyde.ts"}
      inputConfig: {}
      config:
        エリア:
          type: json
          value:
            min: {x: 0, y: 0, z: 0}
            max: {x: 5, y: 5, z: 5}
        移動量: {type: json, value: {x: 5, y: 0, z: 0}}
