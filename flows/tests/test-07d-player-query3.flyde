imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 250
      id: add-tag
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: tag @s add __flyde_test__
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 400
      id: get-player-tags
      inputConfig: {}
      nodeId: GetPlayerTags
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 400
      id: json-077-tags
      inputConfig: {}
      nodeId: JSON Stringify
      config:
        object:
          type: dynamic
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 600
        y: 400
      id: say-077-tags
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: "say [TC-077 タグ一覧] {{v}}"
        トリガー:
          type: boolean
          value: true
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 550
      id: has-tag
      inputConfig: {}
      nodeId: PlayerHasTag
      config:
        タグ:
          type: string
          value: __flyde_test__
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 550
      id: assert-078
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: true
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-078
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 700
      id: remove-tag
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: tag @s remove __flyde_test__
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 850
      id: get-abilities
      inputConfig: {}
      nodeId: GetPlayerAbilities
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 850
      id: json-081-abilities
      inputConfig: {}
      nodeId: JSON Stringify
      config:
        object:
          type: dynamic
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 600
        y: 850
      id: say-081-abilities
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: "say [TC-081 アビリティ] {{v}}"
        トリガー:
          type: boolean
          value: true
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 1000
      id: disconnect
      inputConfig: {}
      nodeId: MinecraftDisconnect
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 900
        y: 350
      id: note-077-081
      inputConfig: {}
      nodeId: Note
      config:
        content: |-
          # TC-077: GetPlayerTags / TC-078: PlayerHasTag / TC-081: GetPlayerAbilities
          **操作手順:**
          1. Minecraft でチャットを 1 回送信する
          2. **自動:** tag @s add __flyde_test__ を実行
          3. **TC-077 目視確認:** MCチャットに `["__flyde_test__"]` が表示されること
          4. **TC-078 自動:** PlayerHasTag("__flyde_test__") = true を Assert → ログで PASS 確認
          5. **自動:** tag @s remove __flyde_test__ でクリーンアップ
          6. **TC-081 目視確認:** MCチャットにアビリティオブジェクトが表示されること
      type: code
      source:
        type: package
        data: "@flyde/nodes"
  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: add-tag
        pinId: トリガー
    - from:
        insId: add-tag
        pinId: 完了
      to:
        insId: get-player-tags
        pinId: トリガー
    - from:
        insId: get-player-tags
        pinId: タグ一覧
      to:
        insId: json-077-tags
        pinId: object
    - from:
        insId: json-077-tags
        pinId: json
      to:
        insId: say-077-tags
        pinId: v
    - from:
        insId: say-077-tags
        pinId: 完了
      to:
        insId: has-tag
        pinId: トリガー
    - from:
        insId: has-tag
        pinId: 結果
      to:
        insId: assert-078
        pinId: 実際値
    - from:
        insId: assert-078
        pinId: 完了
      to:
        insId: remove-tag
        pinId: トリガー
    - from:
        insId: remove-tag
        pinId: 完了
      to:
        insId: get-abilities
        pinId: トリガー
    - from:
        insId: get-abilities
        pinId: アビリティ
      to:
        insId: json-081-abilities
        pinId: object
    - from:
        insId: json-081-abilities
        pinId: json
      to:
        insId: say-081-abilities
        pinId: v
    - from:
        insId: say-081-abilities
        pinId: 完了
      to:
        insId: disconnect
        pinId: トリガー
  id: TestPlayerQuery3
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: |
    プレイヤー追加クエリテスト（TC-077, TC-078, TC-081）チャット送信1回で自動実行
    TC-077: tag add → GetPlayerTags → MCチャットに ["__flyde_test__"] を表示（目視確認）
    TC-078: PlayerHasTag("__flyde_test__") = true を Assert（正常系・自動）
    自動: tag remove でクリーンアップ
    TC-081: GetPlayerAbilities → MCチャットにアビリティを表示（目視確認）
