imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 300
      id: get-local-player
      inputConfig: {}
      nodeId: GetLocalPlayer
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: get-from-player
      inputConfig: {}
      nodeId: GetFromPlayerSnapshot
      config:
        ﾌﾟﾚｲﾔｰ:
          type: dynamic
          value: "{{ﾌﾟﾚｲﾔｰ}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 650
        y: 300
      id: assert-091
      inputConfig: {}
      nodeId: Assert
      config:
        比較:
          type: select
          value: neq
        ID:
          type: string
          value: TC-091
        実際値:
          type: dynamic
          value: "{{実際値}}"
        期待値:
          type: string
          value: ""
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 650
        y: 500
      id: get-from-entity
      inputConfig: {}
      nodeId: GetFromEntity
      config:
        ｴﾝﾃｨﾃｨ:
          type: dynamic
          value: "{{ｴﾝﾃｨﾃｨ}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 950
        y: 500
      id: assert-092
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: number
          value: 0
        比較:
          type: select
          value: gte
        ID:
          type: string
          value: TC-092
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
  connections:
    - from:
        insId: "__this"
        pinId: トリガー
      to:
        insId: get-local-player
        pinId: トリガー
    - from:
        insId: get-local-player
        pinId: プレイヤー
      to:
        insId: get-from-player
        pinId: ﾌﾟﾚｲﾔｰ
    - from:
        insId: get-from-player
        pinId: 名前
      to:
        insId: assert-091
        pinId: 実際値
    - from:
        insId: get-from-player
        pinId: ｴﾝﾃｨﾃｨ
      to:
        insId: get-from-entity
        pinId: ｴﾝﾃｨﾃｨ
    - from:
        insId: get-from-entity
        pinId: ID
      to:
        insId: assert-092
        pinId: 実際値
    - from:
        insId: assert-092
        pinId: 完了
      to:
        insId: "__this"
        pinId: 完了
  id: AutoInfo
  inputs:
    トリガー: "required"
  outputs:
    完了: {}
  inputsPosition:
    トリガー:
      x: -100
      y: 200
  outputsPosition:
    完了:
      x: 950
      y: 1200
  completionOutputs:
    - 完了
  description: |
    自動情報クエリテスト（TC-091,092）
