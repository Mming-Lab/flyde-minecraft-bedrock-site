imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: on-block-broken
      inputConfig: {}
      nodeId: OnBlockBroken
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: json-021-method
      inputConfig: {}
      nodeId: JSON Stringify
      config:
        object:
          type: dynamic
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 557.3608818054199
        y: 312.9578514099121
      id: say-021-method
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: "say [TC-021 破壊方法] {{v}}"
        トリガー:
          type: string
          value: ""
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 655.0688400268555
        y: 142.92456245422363
      id: get-from-block-021
      inputConfig: {}
      nodeId: GetFromBlockType
      config:
        ﾌﾞﾛｯｸ:
          type: dynamic
          value: "{{ﾌﾞﾛｯｸ}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 950
        y: 300
      id: assert-093
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: string
          value: ""
        比較:
          type: select
          value: neq
        ID:
          type: string
          value: TC-093
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 50
        y: 600
      id: on-block-placed
      inputConfig: {}
      nodeId: OnBlockPlaced
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 600
      id: json-022-method
      inputConfig: {}
      nodeId: JSON Stringify
      config:
        object:
          type: dynamic
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 550
        y: 600
      id: say-022-method
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: "say [TC-022 設置方法] {{v}}"
        トリガー:
          type: string
          value: ""
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 694.9487609863281
        y: 499.2000427246094
      id: json-022-block
      inputConfig: {}
      nodeId: JSON Stringify
      config:
        object:
          type: dynamic
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 850
        y: 600
      id: say-022-block
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: "say [TC-022 ブロック] {{v}}"
        トリガー:
          type: string
          value: ""
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 1250
        y: 250
      id: note-021
      inputConfig: {}
      nodeId: Note
      config:
        content: |-
          # TC-021: OnBlockBroken 目視確認
          **操作手順:**
          1. Minecraft でブロックを破壊する
          2. **目視確認:** Minecraft チャットに破壊方法（例: `"player"`）が表示されること
          3. TC-093 は自動: ブロックID が空でないことを Assert → ログで PASS 確認
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 1052.1445922851562
        y: 579.2845458984375
      id: note-022
      inputConfig: {}
      nodeId: Note
      config:
        content: |-
          # TC-022: OnBlockPlaced 目視確認
          **操作手順:**
          1. Minecraft でブロックを設置する
          2. **目視確認:** Minecraft チャットに設置方法（例: `"player"`）とブロック情報が表示されること
      type: code
      source:
        type: package
        data: "@flyde/nodes"
  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-block-broken
        pinId: ワールド
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-block-placed
        pinId: ワールド
    - from:
        insId: on-block-broken
        pinId: 破壊方法
      to:
        insId: json-021-method
        pinId: object
    - from:
        insId: json-021-method
        pinId: json
      to:
        insId: say-021-method
        pinId: v
    - from:
        insId: on-block-broken
        pinId: ﾌﾞﾛｯｸ
      to:
        insId: get-from-block-021
        pinId: ﾌﾞﾛｯｸ
    - from:
        insId: get-from-block-021
        pinId: ブロックID
      to:
        insId: assert-093
        pinId: 実際値
    - from:
        insId: on-block-placed
        pinId: 設置方法
      to:
        insId: json-022-method
        pinId: object
    - from:
        insId: json-022-method
        pinId: json
      to:
        insId: say-022-method
        pinId: v
    - from:
        insId: on-block-placed
        pinId: ﾌﾞﾛｯｸ
      to:
        insId: json-022-block
        pinId: object
    - from:
        insId: json-022-block
        pinId: json
      to:
        insId: say-022-block
        pinId: v
  id: ManualBlockEvents
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: |
    手動テスト（ブロックイベント系 TC-021, TC-022, TC-093）手動操作で各イベントを発火させる
    TC-021: ブロックを破壊 → MCチャットに破壊方法が表示される
    TC-022: ブロックを設置 → MCチャットに設置方法とブロック名が表示される
    TC-093: ブロック破壊 → GetFromBlockType.ブロックID が空でないことをAssert → ログでPASS確認
