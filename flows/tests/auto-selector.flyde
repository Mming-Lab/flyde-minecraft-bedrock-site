imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: selector-block
      inputConfig: {}
      nodeId: Selector
      config:
        種別:
          type: select
          value: block
        ブロック:
          type: select
          value: minecraft:grass_block
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: assert-101
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: string
          value: minecraft:grass_block
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-101
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: locale-name
      inputConfig: {}
      nodeId: ToJa
      config:
        値:
          type: string
          value: minecraft:grass_block
        種別:
          type: select
          value: block
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: assert-102
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: string
          value: 草ブロック
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-102
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../build/index.flyde.js
  connections:
    - from:
        insId: selector-block
        pinId: 値
      to:
        insId: assert-101
        pinId: 実際値
    - from:
        insId: locale-name
        pinId: 日本語名
      to:
        insId: assert-102
        pinId: 実際値
    - from:
        insId: assert-102
        pinId: 完了
      to:
        insId: "__this"
        pinId: 完了
  id: AutoSelector
  inputs:
    トリガー: "required"
  outputs:
    完了: {}
  inputsPosition:
    トリガー:
      x: -100
      y: 200
  outputsPosition:
    完了:
      x: 950
      y: 1200
  completionOutputs:
    - 完了
  description: |
    自動セレクターテスト（TC-101,102）
