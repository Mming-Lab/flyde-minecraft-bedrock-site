    - pos:
        x: 1106.2009582519531
        y: 1256.4830322265625
      id: say-097-name
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: say [TC-097 村人名] {{v}}
        トリガー:
          type: string
          value: ""
