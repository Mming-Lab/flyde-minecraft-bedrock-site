imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: get-orientation
      inputConfig: {}
      nodeId: GetPlayerOrientation
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: assert-073
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: number
          value: -180
        比較:
          type: select
          value: gte
        ID:
          type: string
          value: TC-073
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 500
      id: player-has-tag
      inputConfig: {}
      nodeId: PlayerHasTag
      config:
        タグ:
          type: string
          value: __flyde_test_tag__
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 500
      id: assert-078
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: false
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-078
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 700
      id: update-ability
      inputConfig: {}
      nodeId: UpdateAbility
      config:
        アビリティ:
          type: select
          value: mayfly
        値:
          type: boolean
          value: false
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 700
      id: assert-082
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: true
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-082
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 900
      id: get-players
      inputConfig: {}
      nodeId: GetPlayers
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 900
      id: broadcast-players
      inputConfig: {}
      nodeId: BroadcastMessage
      config:
        メッセージ:
          type: dynamic
          value: "{{メッセージ}}"
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 650
        y: 900
      id: assert-083
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: true
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-083
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 1100
      id: disconnect
      inputConfig: {}
      nodeId: MinecraftDisconnect
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: get-orientation
        pinId: トリガー
    - from:
        insId: get-orientation
        pinId: 角度
      to:
        insId: assert-073
        pinId: 実際値
    - from:
        insId: assert-073
        pinId: 完了
      to:
        insId: player-has-tag
        pinId: トリガー
    - from:
        insId: player-has-tag
        pinId: 結果
      to:
        insId: assert-078
        pinId: 実際値
    - from:
        insId: assert-078
        pinId: 完了
      to:
        insId: update-ability
        pinId: トリガー
    - from:
        insId: update-ability
        pinId: 完了
      to:
        insId: assert-082
        pinId: 実際値
    - from:
        insId: assert-082
        pinId: 完了
      to:
        insId: get-players
        pinId: トリガー
    - from:
        insId: get-players
        pinId: プレイヤー一覧
      to:
        insId: broadcast-players
        pinId: メッセージ
    - from:
        insId: broadcast-players
        pinId: 完了
      to:
        insId: assert-083
        pinId: 実際値
    - from:
        insId: assert-083
        pinId: 完了
      to:
        insId: disconnect
        pinId: トリガー
  id: TestPlayerMisc
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: プレイヤー系追加テスト（TC-073/078/082/083）チャット送信1回で自動実行
