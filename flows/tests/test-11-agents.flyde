imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 700
        y: 30
      id: note-overview
      inputConfig: {}
      nodeId: Note
      config:
        content: |-
          # エージェントテスト（TC-131〜145）実行手順

          ## 実行方法（2回実行が必要）

          ### 1回目の実行
          1. フローを起動する
          2. Minecraft でチャットを 1 回送信する
          3. TC-131（AgentTP）と TC-132（AG座標取得）が自動実行される
          4. ログで TC-131/132 の PASS を確認
          5. フローを停止する

          ### 2回目の実行
          1. フローを再起動する（Minecraftは切断せずそのまま）
          2. TC-133〜145 が自動で順次実行される
             - エージェントが前方に移動・回転・攻撃・ブロック設置等を行う
          3. ログで各 TC の PASS/FAIL を確認

          **なぜ2回必要か?**
          コンテキスト（プレイヤー情報）は初回チャット時に設定され
          OS プロセスに保持されるため、2回目の起動時に再利用される。

          ※ Education Edition 専用。エージェントが存在しない場合は自動作成。
      type: code
      source:
        type: package
        data: "@flyde/nodes"
    - pos:
        x: 50
        y: 300
      id: agent-tp
      inputConfig: {}
      nodeId: AgentTeleport
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
