imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: run-cmd
      inputConfig: {}
