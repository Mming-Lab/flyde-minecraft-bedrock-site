      config:
        コマンド:
          type: string
          value: time set day
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: assert-051
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: true
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-051
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
