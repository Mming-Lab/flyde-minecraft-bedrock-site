imports: {}
node:
  instances:
    - pos:
        x: 50
        y: 100
      id: mc-connect
      inputConfig: {}
      nodeId: MinecraftConnect
      config:
        ポート:
          type: dynamic
          value: "{{ポート}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 100
      id: on-chat
      inputConfig: {}
      nodeId: OnPlayerChat
      config:
        ワールド:
          type: dynamic
          value: "{{ワールド}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 300
      id: run-cmd
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: time set day
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 300
      id: assert-051
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: boolean
          value: true
        比較:
          type: select
          value: eq
        ID:
          type: string
          value: TC-051
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 50
        y: 500
      id: get-top-block
      inputConfig: {}
      nodeId: GetTopSolidBlock
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 334.78758239746094
        y: 480.85498046875
      id: vec-split-060
      inputConfig: {}
      nodeId: Vector3Split
      config:
        座標:
          type: dynamic
          value: "{{座標}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 650
        y: 500
      id: assert-060
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: number
          value: -64
        比較:
          type: select
          value: gte
        ID:
          type: string
          value: TC-060
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 53.1485595703125
        y: 647.2295532226562
      id: setblock-064
      inputConfig: {}
      nodeId: RunCommand
      config:
        コマンド:
          type: string
          value: setblock 0 30 0 minecraft:dirt
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 181.8556671142578
        y: 781.9288635253906
      id: fill-blocks
      inputConfig: {}
      nodeId: FillBlocks
      config:
        始点:
          type: json
          value:
            x: 0
            y: 30
            z: 0
        終点:
          type: json
          value:
            x: 0
            y: 30
            z: 0
        ブロックID:
          type: string
          value: minecraft:air
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 579.8536071777344
        y: 697.8960266113281
      id: assert-064
      inputConfig: {}
      nodeId: Assert
      config:
        期待値:
          type: number
          value: 0
        比較:
          type: select
          value: gte
        ID:
          type: string
          value: TC-064
        実際値:
          type: dynamic
          value: "{{実際値}}"
        許容差:
          type: number
          value: 0.001
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
    - pos:
        x: 350
        y: 900
      id: disconnect
      inputConfig: {}
      nodeId: MinecraftDisconnect
      config:
        トリガー:
          type: dynamic
          value: "{{トリガー}}"
      type: code
      source:
        type: file
        data: ../../dist/index.flyde.js
  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: run-cmd
        pinId: トリガー
    - from:
        insId: run-cmd
        pinId: 完了
      to:
        insId: assert-051
        pinId: 実際値
    - from:
        insId: assert-051
        pinId: 完了
      to:
        insId: get-top-block
        pinId: トリガー
    - from:
        insId: get-top-block
        pinId: 座標
      to:
        insId: vec-split-060
        pinId: 座標
    - from:
        insId: vec-split-060
        pinId: y
      to:
        insId: assert-060
        pinId: 実際値
    - from:
        insId: assert-060
        pinId: 完了
      to:
        insId: setblock-064
        pinId: トリガー
    - from:
        insId: setblock-064
        pinId: 完了
      to:
        insId: fill-blocks
        pinId: トリガー
    - from:
        insId: fill-blocks
        pinId: 個数
      to:
        insId: assert-064
        pinId: 実際値
    - from:
        insId: assert-064
        pinId: 完了
      to:
        insId: disconnect
        pinId: トリガー
  id: TestGameplay2
  inputs: {}
  outputs: {}
  inputsPosition: {}
  outputsPosition: {}
  completionOutputs: []
  description: ゲームプレイ系コマンド追加テスト（TC-051/060/064）チャット送信1回で自動実行
