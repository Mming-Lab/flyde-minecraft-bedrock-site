  connections:
    - from:
        insId: mc-connect
        pinId: ワールド
      to:
        insId: on-chat
        pinId: ワールド
    - from:
        insId: on-chat
        pinId: 送信者名
      to:
        insId: run-cmd
        pinId: トリガー
    - from:
        insId: run-cmd
        pinId: 完了
      to:
        insId: assert-051
        pinId: 実際値
    - from:
        insId: assert-051
        pinId: 完了
      to:
        insId: get-top-block
        pinId: トリガー
    - from:
        insId: get-top-block
        pinId: 座標
      to:
        insId: vec-split-060
        pinId: 座標
    - from:
        insId: vec-split-060
        pinId: y
      to:
        insId: assert-060
        pinId: 実際値
    - from:
        insId: assert-060
        pinId: 完了
      to:
